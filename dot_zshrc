# Enable Powerlevel10k instant prompt. Should stay close to the top of .zshrc.
# Initialization code that may require console input (password prompts, [y/n]
# confirmations, etc.) must go above this block; everything else may go below.
export XDG_CONFIG_HOME=${XDG_CONFIG_HOME:-$HOME/.config}
export XDG_DATA_HOME=${XDG_DATA_HOME:-$HOME/.local/share}
export XDG_CACHE_HOME=${XDG_CACHE_HOME:-$HOME/.cache}

# Deduplicate PATH
typeset -U path

if [[ -r "${XDG_CACHE_HOME}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# --- Plugin management (no external plugin manager) ---
ZSH_PLUGIN_DIR="${XDG_DATA_HOME}/zsh/plugins"

# Clone a plugin from GitHub if not already present
_zsh_clone_plugin() {
  local repo="$1" dest="$ZSH_PLUGIN_DIR/${1##*/}"
  [[ -d "$dest" ]] || git clone --depth 1 "https://github.com/$repo.git" "$dest" 2>/dev/null
}

# Update all plugins
zsh-plugin-update() {
  for dir in "$ZSH_PLUGIN_DIR"/*(N/); do
    echo "Updating ${dir:t}..."
    git -C "$dir" pull --ff-only
  done
}

# Clone plugins on first run
_zsh_clone_plugin romkatv/powerlevel10k
_zsh_clone_plugin zsh-users/zsh-completions
_zsh_clone_plugin aloxaf/fzf-tab
_zsh_clone_plugin zdharma-continuum/fast-syntax-highlighting
_zsh_clone_plugin zsh-users/zsh-autosuggestions
_zsh_clone_plugin zsh-users/zsh-history-substring-search

# Completions (add to fpath before compinit)
fpath=("$ZSH_PLUGIN_DIR/zsh-completions/src" $fpath)

# Initialize completions
autoload -Uz compinit && compinit

# Source plugins (order matters: fzf-tab after compinit, syntax-highlighting last)
source "$ZSH_PLUGIN_DIR/powerlevel10k/powerlevel10k.zsh-theme"
source "$ZSH_PLUGIN_DIR/fzf-tab/fzf-tab.plugin.zsh"
source "$ZSH_PLUGIN_DIR/zsh-autosuggestions/zsh-autosuggestions.zsh"
source "$ZSH_PLUGIN_DIR/zsh-history-substring-search/zsh-history-substring-search.zsh"
source "$ZSH_PLUGIN_DIR/fast-syntax-highlighting/fast-syntax-highlighting.plugin.zsh"

# --- History (replaces belak/zsh-utils history) ---
HISTFILE="${HOME}/.zsh_history"
HISTSIZE=10000
SAVEHIST=10000
setopt EXTENDED_HISTORY
setopt HIST_EXPIRE_DUPS_FIRST
setopt HIST_FIND_NO_DUPS
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_VERIFY
setopt SHARE_HISTORY

# --- Utility options (replaces belak/zsh-utils utility) ---
setopt AUTO_CD
setopt AUTO_PUSHD
setopt PUSHD_IGNORE_DUPS
setopt PUSHD_SILENT
setopt INTERACTIVE_COMMENTS
setopt NO_BEEP

# To customize prompt, run `p10k configure` or edit ~/.p10k.zsh.
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

eval "$(mise activate zsh)"

# Source alias and function files
[[ -f "$XDG_CONFIG_HOME/zsh/aliases.zsh" ]] && source "$XDG_CONFIG_HOME/zsh/aliases.zsh"
[[ -f "$XDG_CONFIG_HOME/zsh/work-aliases.zsh" ]] && source "$XDG_CONFIG_HOME/zsh/work-aliases.zsh"
[[ -f "$XDG_CONFIG_HOME/zsh/functions.zsh" ]] && source "$XDG_CONFIG_HOME/zsh/functions.zsh"
[[ -f "$XDG_CONFIG_HOME/zsh/work-functions.zsh" ]] && source "$XDG_CONFIG_HOME/zsh/work-functions.zsh"

# VS Code shell integration
[[ "$TERM_PROGRAM" == "vscode" ]] && command -v code &>/dev/null && . "$(code --locate-shell-integration-path zsh)"

# Additional PATH entries
[[ -d "$HOME/.amp/bin" ]] && path=("$HOME/.amp/bin" $path)
[[ -d "$HOME/.opencode/bin" ]] && path=("$HOME/.opencode/bin" $path)
[[ -d "$HOME/.local/bin" ]] && path=("$HOME/.local/bin" $path)
