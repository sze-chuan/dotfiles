#!/bin/bash
set -euo pipefail

{{- if eq .chezmoi.os "darwin" }}

# --- macOS (Homebrew) ---

if ! command -v brew &>/dev/null; then
  echo "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$(/opt/homebrew/bin/brew shellenv)"
fi

brew_packages=(
  mise                          # dev tool version manager
  eza                           # modern ls replacement
  fzf                           # fuzzy finder
  powerlevel10k                 # zsh prompt theme
  zsh-autosuggestions           # fish-like autosuggestions
  zsh-completions               # additional completions
  zsh-history-substring-search  # up/down history search
  zsh-syntax-highlighting       # fish-like syntax highlighting
)

brew_casks=(
  ghostty    # terminal emulator
)

echo "Installing brew packages..."
brew install "${brew_packages[@]}"

echo "Installing brew casks..."
brew install --cask "${brew_casks[@]}" 2>/dev/null || true

{{- else if eq .chezmoi.osRelease.id "arch" }}

# --- Omarchy / Arch Linux (pacman + yay) ---

pacman_packages=(
  zsh
  eza
  fzf
  mise
  zsh-autosuggestions
  zsh-completions
  zsh-history-substring-search
  zsh-syntax-highlighting
)

echo "Installing pacman packages..."
sudo pacman -S --needed --noconfirm "${pacman_packages[@]}"

# AUR: powerlevel10k
if command -v yay &>/dev/null; then
  echo "Installing AUR packages..."
  yay -S --needed --noconfirm zsh-theme-powerlevel10k
else
  echo "Warning: yay not found, skipping AUR packages (powerlevel10k)"
  echo "Install yay and run: yay -S zsh-theme-powerlevel10k"
fi

{{- else if eq .chezmoi.osRelease.id "ol" }}

# --- Oracle Enterprise Linux 9 (dnf + Homebrew) ---

if ! command -v brew &>/dev/null; then
  echo "Installing Homebrew..."
  /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

brew_packages=(
  mise                          # dev tool version manager
  eza                           # modern ls replacement
  fzf                           # fuzzy finder
  powerlevel10k                 # zsh prompt theme
  zsh-autosuggestions           # fish-like autosuggestions
  zsh-completions               # additional completions
  zsh-history-substring-search  # up/down history search
  zsh-syntax-highlighting       # fish-like syntax highlighting
)

echo "Installing brew packages..."
brew install "${brew_packages[@]}"

{{- end }}

echo "Bootstrap complete."
