{{- if eq .chezmoi.os "darwin" -}}
# Ghostty Configuration (macOS)

# Split terminal keybindings
keybind = super+shift+o=new_split:right
keybind = super+shift+e=new_split:down

# Navigate between splits
keybind = super+alt+left=goto_split:left
keybind = super+alt+right=goto_split:right
keybind = super+alt+up=goto_split:top
keybind = super+alt+down=goto_split:bottom

# Resize splits
keybind = super+shift+ctrl+left=resize_split:left,10
keybind = super+shift+ctrl+right=resize_split:right,10
keybind = super+shift+ctrl+up=resize_split:up,10
keybind = super+shift+ctrl+down=resize_split:down,11
{{- else if eq .chezmoi.osRelease.id "arch" -}}
# Ghostty Configuration (Arch Linux / Omarchy)
# super is grabbed by Hyprland, so use ctrl+shift for splits

# Split terminal keybindings
keybind = ctrl+shift+o=new_split:right
keybind = ctrl+shift+e=new_split:down

# Navigate between splits
keybind = ctrl+shift+left=goto_split:left
keybind = ctrl+shift+right=goto_split:right
keybind = ctrl+shift+up=goto_split:top
keybind = ctrl+shift+down=goto_split:bottom

# Resize splits
keybind = ctrl+shift+alt+left=resize_split:left,10
keybind = ctrl+shift+alt+right=resize_split:right,10
keybind = ctrl+shift+alt+up=resize_split:up,10
keybind = ctrl+shift+alt+down=resize_split:down,10
{{- end -}}

